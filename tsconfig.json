{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2022", "DOM"],
  "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist"
  },
  "extends": "./.nuxt/tsconfig.json",
  "include": ["types", "scripts", "utilities", "**/*", ".nuxt", "nuxt.config.ts"]
}