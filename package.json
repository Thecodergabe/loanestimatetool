{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "test": "npx vitest run",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "convert:insurance": "powershell -Command if (Test-Path dist\\convertXLSX.cjs) { Remove-Item dist\\convertXLSX.cjs -Force }; npx tsc utilities/convertXLSX.ts --outDir dist; if (Test-Path dist\\convertXLSX.js) { Rename-Item -Path dist\\convertXLSX.js -NewName convertXLSX.cjs -Force }; if (Test-Path dist\\convertXLSX.cjs) { node dist\\convertXLSX.cjs } else { Write-Host '❌ convertXLSX.cjs not found after build.' }",
    "build:test-tax": "tsc scripts/test-tax.ts --outDir dist",
    "generate:zip-tax": "powershell -ExecutionPolicy Bypass -File ./scripts/generate-zip-tax.ps1",
    "generate:tax": "tsc scripts/test-tax.ts --outDir dist --module ESNext && node dist/scripts/test-tax.js"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@nuxt/eslint": "^1.5.0",
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/icon": "^1.15.0",
    "@nuxt/image": "^1.10.0",
    "@nuxt/test-utils": "^3.19.2",
    "chart.js": "^4.5.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "cheerio": "^1.1.0",
    "csv": "^6.3.11",
    "eslint": "^9.30.1",
    "nuxt": "^3.17.6",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfmake": "^0.2.20",
    "undici": "^7.11.0",
    "vue": "^3.5.17",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node": "^18.18.6",
    "@types/papaparse": "^5.3.16",
    "@types/pdfmake": "^0.2.11",
    "@vitest/ui": "^3.2.4",
    "typescript": "^5.4.5",
    "undici-types": "^7.11.0",
    "vite-plugin-vuetify": "^2.1.1",
    "vitest": "^3.2.4",
    "vuetify": "^3.8.11"
  }
}
