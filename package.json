{
  "name": "loan-estimate-tool",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "fake": "npx wrangler pages dev",
    "clean": "rimraf .nuxt dist .output && npm run build",
    "clean:start": "npm run clean && npm run fake",
    "lint": "npx eslint . --ext .ts,.vue --fix",
    "start": "npm run build && npm run preview",
    "test": "npx vitest run",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "convert:insurance": "powershell -Command \"if (Test-Path dist\\convertXLSX.cjs) { Remove-Item dist\\convertXLSX.cjs -Force }; npx tsc utilities/convertXLSX.ts --outDir dist; if (Test-Path dist\\convertXLSX.js) { Rename-Item -Path dist\\convertXLSX.js -NewName convertXLSX.cjs -Force }; if (Test-Path dist\\convertXLSX.cjs) { node dist\\convertXLSX.cjs } else { Write-Host '❌ convertXLSX.cjs not found after build.' }\"",
    "build:test-tax": "tsc scripts/test-tax.ts --outDir dist",
    "generate:zip-tax": "powershell -ExecutionPolicy Bypass -File ./scripts/generate-zip-tax.ps1",
    "generate:tax": "tsc scripts/test-tax.ts --outDir dist --module ESNext && node dist/scripts/test-tax.js"
  },
  "dependencies": {
    "@nuxtjs/robots": "^5.3.0",
    "chart.js": "^4.4.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "cheerio": "^1.0.0",
    "commander": "^14.0.3",
    "csv-parse": "^5.6.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "node-fetch": "^3.3.2",
    "nuxt": "^3.12.4",
    "vue": "^3.4.31",
    "vue-chartjs": "^5.3.1",
    "vuetify": "^3.6.14",
    "vuetify-nuxt-module": "^0.18.3",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.5.0",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20.14.9",
    "@vitest/ui": "^1.6.0",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.5.2",
    "vite-plugin-compression2": "^1.1.2",
    "vitest": "^1.6.0",
    "wrangler": "^3.62.0"
  },
  "overrides": {
    "@nuxt/eslint-config": {
      "eslint": "$eslint"
    }
  }
}
